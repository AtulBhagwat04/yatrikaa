GOOGLE_PLACES_API_KEY=your_api_key_here
PORT=3000
MONGODB_URI=mongodb://localhost:27017/YatrikaaApp
JWT_SECRET=your_jwt_secret_here

# Admin Credentials (Set these in your local .env file)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password

# Super-Admin Credentials (Set these in your local .env file)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=your_secure_password

# Cloudinary Credentials
CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Geopify Places API (used as fallback for some searches)
GEOPIFY_PLACES_API_KEY=your_geopify_api_key_here

# Firebase Configuration (for Push Notifications and Admin SDK)
# Use either FIREBASE_SERVICE_ACCOUNT_JSON (entire JSON as a single string)
# OR provide individual fields below:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

